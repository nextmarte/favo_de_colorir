---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Favo de Colorir — ateliê de cerâmica em Tijuca, RJ',
  description = 'Ateliê de cerâmica em Tijuca, RJ, desde 2018. Aulas regulares, oficinas e avulsas — com um app que acompanha cada pessoa da turma no dia a dia.',
  ogImage = '/og-default.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://favodecolorir.com.br').toString();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFF8F4" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, canonical).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Manrope:wght@400;500;600;700&display=swap"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: 'Favo de Colorir',
      description,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Tijuca',
        addressRegion: 'RJ',
        addressCountry: 'BR',
      },
      url: 'https://favodecolorir.com.br',
      sameAs: ['https://instagram.com/favodecolorir'],
    })} />
  </head>
  <body>
    <a class="skip-link" href="#hero-title">Pular para o conteúdo</a>
    <slot />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 1rem;
        padding: 0.5rem 1rem;
        background: var(--on-surface);
        color: var(--surface);
        border-radius: var(--r-pill);
        z-index: 100;
      }
      .skip-link:focus { left: 1rem; }
    </style>
  </body>
</html>
