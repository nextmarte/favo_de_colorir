---
interface Prop {
  number: string;
  title: string;
  body: string;
}

const props: Prop[] = [
  {
    number: '01',
    title: 'Sua turma, seu horário',
    body: 'Escolhe um dia e fica na mesma turma — como quem tem o café de domingo marcado. Se a vida pede, dá pra trocar.',
  },
  {
    number: '02',
    title: 'Se faltar, a gente repõe',
    body: 'Faltou? Abre o app, escolhe outro dia que tem vaga e marca. Sem cobrar, sem papel na mão, sem peso na consciência.',
  },
  {
    number: '03',
    title: 'Um toque pra avisar que vai',
    body: 'Na véspera você diz “vou” ou “não vou”. A Débora prepara o ateliê sem contar cabeça no WhatsApp — e o grupo fica pra coisa boa.',
  },
  {
    number: '04',
    title: 'Uma conversa entre quem faz aula',
    body: 'Um feed dentro do ateliê pra mostrar peça, pedir dica, comemorar a queima que saiu boa. Moderação automática cuida do tom.',
  },
  {
    number: '05',
    title: 'O caderno da sua peça',
    body: 'Cada peça ganha foto e nota. Modelou, pintou, queimou, tá pronta pra buscar — tudo guardadinho, sem você precisar lembrar.',
  },
];
---

<section class="vp section section--surface-mid" aria-labelledby="vp-title">
  <div class="container vp__inner">
    <header class="vp__head">
      <span class="eyebrow">No dia a dia</span>
      <h2 id="vp-title" class="section-title">
        Um ateliê calmo — e um app que <em>não atrapalha</em>.
      </h2>
    </header>

    <ol class="vp__list">
      {
        props.map((p) => (
          <li class="vp__item">
            <span class="vp__num">{p.number}</span>
            <div class="vp__copy">
              <h3 class="vp__title">{p.title}</h3>
              <p class="vp__body">{p.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .vp__inner { display: grid; gap: clamp(2rem, 4vw, 3.5rem); }

  .vp__head {
    display: grid;
    gap: var(--s-4);
    max-width: 52rem;
  }

  .vp__head em {
    font-style: italic;
    color: var(--secondary);
    font-weight: 500;
  }

  .vp__list {
    display: grid;
    gap: var(--s-4);
  }

  .vp__item {
    display: grid;
    grid-template-columns: clamp(3rem, 6vw, 5.5rem) 1fr;
    gap: var(--s-6);
    padding-block: var(--s-6);
    border-bottom: 1px dashed rgba(133, 117, 104, 0.32);
    align-items: start;
  }

  .vp__item:first-child { border-top: 1px dashed rgba(133, 117, 104, 0.32); }

  .vp__num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    letter-spacing: var(--tracking-display);
    color: var(--secondary);
    line-height: 1;
  }

  .vp__copy { display: grid; gap: var(--s-3); }

  .vp__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.6vw, 1.6rem);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
  }

  .vp__body {
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
    color: var(--on-surface-muted);
    max-width: 48rem;
  }
</style>
