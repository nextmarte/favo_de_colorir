---
import Card from './ui/Card.astro';

interface Feature {
  title: string;
  body: string;
  icon: 'agenda' | 'materiais' | 'cobranca' | 'feed' | 'comunidade';
}

const features: Feature[] = [
  {
    title: 'Sua agenda, semana a semana',
    body: 'Calendário da turma, reposição em tempo real, confirmação num toque.',
    icon: 'agenda',
  },
  {
    title: 'Materiais da sua aula',
    body: 'Quilos de argila, peças em queima, devolução — tudo registrado pela Débora, visível pra você.',
    icon: 'materiais',
  },
  {
    title: 'Extrato claro, Pix no app',
    body: 'Mensalidade, argila e queima totalizadas no primeiro dia útil. Paga direto no app, sem boleto escondido.',
    icon: 'cobranca',
  },
  {
    title: 'O caderno das suas peças',
    body: 'Cada peça é uma página: foto, anotação, etapa. Para lembrar do processo, não só do resultado.',
    icon: 'feed',
  },
  {
    title: 'A comunidade do ateliê',
    body: 'Posts, curtidas, chat com a professora. Sem DM entre quem não se conhece, sem ruído externo.',
    icon: 'comunidade',
  },
];

// Inline icon paths (24x24 viewBox)
const icons: Record<Feature['icon'], string> = {
  agenda:
    'M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm-1 6h16M8 2v4M16 2v4M9 14h6',
  materiais:
    'M4 7l8-4 8 4-8 4-8-4zm0 5l8 4 8-4M4 17l8 4 8-4',
  cobranca:
    'M3 7h18v10H3zM3 11h18M7 15h2m4 0h4',
  feed:
    'M4 5h12a2 2 0 0 1 2 2v14H6a2 2 0 0 1-2-2V5zm0 0h16M8 9h6m-6 4h8m-8 4h5',
  comunidade:
    'M3 12a8 8 0 0 1 14.93-4M21 12a8 8 0 0 1-14.93 4M8 9l-4 1 1-4M16 15l4-1-1 4',
};
---

<section id="produto" class="features section">
  <div class="container">
    <header class="features__head">
      <span class="eyebrow">O que o app faz por você</span>
      <h2 class="section-title">O app do Favo, do seu lado em cada etapa no ateliê.</h2>
    </header>

    <ul class="features__grid">
      {
        features.map((f) => (
          <li>
            <Card tone="paper" class="feature">
              <header class="feature__head">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                    <path d={icons[f.icon]} />
                  </svg>
                </span>
              </header>
              <h3 class="feature__title">{f.title}</h3>
              <p class="feature__body">{f.body}</p>
            </Card>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features__head {
    display: grid;
    gap: var(--s-4);
    max-width: 50rem;
    margin-block-end: clamp(2rem, 4vw, 3rem);
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    gap: var(--s-5);
  }

  .feature {
    display: grid;
    gap: var(--s-4);
    height: 100%;
  }

  .feature__head {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .feature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--r-pill);
    background: var(--surface-mid);
    color: var(--primary);
  }

  .feature__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
  }

  .feature__body {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--on-surface-muted);
  }
</style>
