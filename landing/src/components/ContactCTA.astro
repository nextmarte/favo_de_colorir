---
const mapQuery = encodeURIComponent('Rua São Francisco Xavier, 32, Tijuca, Rio de Janeiro, RJ');
const mapEmbedUrl = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
---

<section id="contato" class="contact section">
  <div class="container contact__inner">
    <div class="contact__copy">
      <span class="eyebrow">Conversar</span>
      <h2 class="section-title contact__title">
        Mande uma mensagem,<br />
        <em>responde uma pessoa.</em>
      </h2>
      <p class="prose">
        Pra conhecer planos, combinar uma visita ao ateliê ou tirar qualquer
        dúvida — chama a Débora no WhatsApp. Sem formulário, sem fila, sem
        robô: é ela mesma que responde.
      </p>

      <div class="contact__map">
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="240"
          style="border:0; border-radius: var(--r-card);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Localização do ateliê Favo de Colorir"
        ></iframe>
        <p class="contact__address">
          <strong>Rua São Francisco Xavier, 32</strong> — Tijuca, Rio de Janeiro, RJ
        </p>
      </div>
    </div>

    <aside class="contact__card" aria-labelledby="contact-card-title">
      <p class="eyebrow contact__card-eyebrow">Fale com a Débora</p>
      <h3 id="contact-card-title" class="contact__card-title">Vem dar uma passada</h3>

      <ul class="contact__channels">
        <li>
          <span class="contact__channel-label">WhatsApp</span>
          <a href="https://wa.me/" class="contact__channel-value" data-todo="numero-real">+55 (21) — a confirmar</a>
        </li>
        <li>
          <span class="contact__channel-label">Instagram</span>
          <a href="https://instagram.com/favodecolorir" class="contact__channel-value" data-todo="handle-real">@favodecolorir</a>
        </li>
        <li>
          <span class="contact__channel-label">E-mail</span>
          <a href="mailto:contato@favodecolorir.com.br" class="contact__channel-value" data-todo="email-real">contato@favodecolorir.com.br</a>
        </li>
      </ul>

      <div id="alunas" class="contact__alunas">
        <p class="contact__alunas-label">Já faz aula no ateliê?</p>
        <div class="contact__stores">
          <a
            class="store-badge"
            href="#"
            data-todo="link-real-app-store"
            aria-label="Baixar na App Store"
          >
            <svg class="store-badge__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                fill="currentColor"
                d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
              />
            </svg>
            <span class="store-badge__copy">
              <span class="store-badge__small">Baixar na</span>
              <span class="store-badge__big">App Store</span>
            </span>
          </a>

          <a
            class="store-badge"
            href="#"
            data-todo="link-real-google-play"
            aria-label="Baixar no Google Play"
          >
            <svg class="store-badge__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                fill="currentColor"
                d="M4.5 3.1 15.6 12 4.5 20.9a.9.9 0 0 1-.5-.8V3.9a.9.9 0 0 1 .5-.8zm12.4 7.2 2.9 1.6a.9.9 0 0 1 0 1.6l-2.9 1.6L14.2 12zM5.5 2.1l11.3 6.5-2.6 2.6zm11.3 19.8L5.5 21.9l8.7-8.7z"
              />
            </svg>
            <span class="store-badge__copy">
              <span class="store-badge__small">Disponível no</span>
              <span class="store-badge__big">Google Play</span>
            </span>
          </a>
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .contact {
    background:
      linear-gradient(180deg, var(--surface) 0%, var(--surface-low) 100%);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  @media (min-width: 880px) {
    .contact__inner { grid-template-columns: 1.05fr 1fr; }
  }

  .contact__copy { display: grid; gap: var(--s-5); max-width: 36rem; }

  .contact__map {
    display: grid;
    gap: var(--s-3);
    margin-block-start: var(--s-2);
  }

  .contact__map iframe {
    width: 100%;
    min-height: 220px;
    border-radius: var(--r-card);
  }

  .contact__address {
    font-size: 0.95rem;
    color: var(--on-surface-muted);
    line-height: 1.4;
  }

  .contact__title em {
    font-style: italic;
    color: var(--secondary);
    font-weight: 500;
  }

  .contact__card {
    background: var(--on-surface);
    color: var(--surface);
    border-radius: var(--r-card);
    padding: clamp(2rem, 4vw, 2.75rem);
    display: grid;
    gap: var(--s-5);
    position: relative;
    overflow: hidden;
  }

  .contact__card::before {
    content: '';
    position: absolute;
    inset: -40% -10% auto auto;
    width: 22rem;
    height: 22rem;
    background: radial-gradient(circle, rgba(199, 91, 57, 0.55), transparent 65%);
    border-radius: 50%;
    z-index: 0;
  }

  .contact__card > * { position: relative; z-index: 1; }

  .contact__card-eyebrow {
    color: rgba(255, 248, 244, 0.7);
  }

  .contact__card-eyebrow::before {
    background: rgba(255, 248, 244, 0.4);
  }

  .contact__card-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.4rem + 1.2vw, 2.1rem);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
  }

  .contact__channels {
    display: grid;
    gap: var(--s-4);
    padding-block-start: var(--s-4);
    border-top: 1px dashed rgba(255, 248, 244, 0.18);
  }

  .contact__channels li {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: var(--s-4);
    align-items: baseline;
  }

  .contact__channel-label {
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: rgba(255, 248, 244, 0.6);
  }

  .contact__channel-value {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--surface);
    border-bottom: 1px dashed rgba(255, 248, 244, 0.4);
    transition: border-color var(--d-fast) var(--ease-out);
  }

  .contact__channel-value:hover { border-color: var(--secondary); }

  .contact__alunas {
    display: grid;
    gap: var(--s-3);
    padding-block-start: var(--s-4);
    border-top: 1px dashed rgba(255, 248, 244, 0.18);
  }

  .contact__alunas-label {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: rgba(255, 248, 244, 0.7);
  }

  .contact__stores {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--s-3);
  }

  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 0.95rem 0.6rem 0.8rem;
    background: var(--surface);
    color: var(--on-surface);
    border-radius: var(--r-pill);
    text-decoration: none;
    line-height: 1.1;
    transition: transform var(--d-fast) var(--ease-out), box-shadow var(--d-fast) var(--ease-out);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
  }

  .store-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.22);
  }

  .store-badge:focus-visible {
    outline: 2px solid var(--secondary);
    outline-offset: 3px;
  }

  .store-badge__icon {
    width: 1.7rem;
    height: 1.7rem;
    flex-shrink: 0;
  }

  .store-badge__copy {
    display: grid;
    gap: 1px;
  }

  .store-badge__small {
    font-size: 0.66rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    opacity: 0.7;
  }

  .store-badge__big {
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
  }
</style>
