---
// Ponte de autenticação: Supabase redireciona pra cá após confirmação
// de email, reset de senha ou magic link. A página tenta abrir o app
// via deep link `favo://auth-callback?...` e cai em fallback visual
// se não conseguir (browser desktop, app não instalado).
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Abrindo o Favo de Colorir…</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        // Repassa query + hash fragments pro app (Supabase usa hash pra
        // tokens de access_token/refresh_token em alguns fluxos).
        var search = window.location.search || '';
        var hash = window.location.hash || '';
        var deepLink = 'favo://auth-callback' + search + hash;

        // Tenta abrir o app. Se o scheme não estiver registrado,
        // o navegador não faz nada e a página segue mostrando o fallback.
        setTimeout(function () {
          window.location.href = deepLink;
        }, 300);

        // Revela o fallback depois de 2s caso o deep link falhe.
        setTimeout(function () {
          var el = document.getElementById('fallback');
          if (el) el.classList.add('visible');
        }, 2000);
      })();
    </script>
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family:
          system-ui,
          -apple-system,
          'Manrope',
          'Segoe UI',
          sans-serif;
        background:
          radial-gradient(60rem 40rem at 30% 10%, #ffdcc3 0%, transparent 60%),
          radial-gradient(50rem 50rem at 85% 80%, #ffd9b5 0%, transparent 60%),
          #fff7ee;
        color: #3a1d00;
      }
      main {
        max-width: 28rem;
        padding: 2.5rem;
        text-align: center;
      }
      .spinner {
        width: 48px;
        height: 48px;
        border: 3px solid #c75b39;
        border-top-color: transparent;
        border-radius: 50%;
        margin: 0 auto 1.5rem;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      h1 {
        font-family: 'Epilogue', system-ui, sans-serif;
        font-size: 1.75rem;
        margin: 0 0 0.75rem;
        line-height: 1.2;
      }
      p {
        margin: 0 0 0.75rem;
        line-height: 1.5;
        color: #5d1900;
      }
      .fallback {
        opacity: 0;
        transition: opacity 0.35s ease;
        margin-top: 2rem;
        border-top: 1px solid #c75b3933;
        padding-top: 1.5rem;
      }
      .fallback.visible {
        opacity: 1;
      }
      .stores {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
        margin-top: 1.25rem;
      }
      .store {
        padding: 0.75rem 1.25rem;
        background: #3a1d00;
        color: #fff7ee;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.875rem;
      }
      .store--alt {
        background: transparent;
        color: #3a1d00;
        border: 1.5px solid #3a1d00;
      }
      a.open-again {
        display: inline-block;
        margin-top: 1rem;
        color: #c75b39;
        font-weight: 600;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="spinner" aria-hidden="true"></div>
      <h1>Abrindo o app…</h1>
      <p>Se o Favo de Colorir estiver instalado, ele vai abrir em 1 segundo.</p>

      <div id="fallback" class="fallback">
        <p><strong>Não abriu?</strong></p>
        <p>
          Ou você tá no desktop, ou ainda não instalou o app. Baixa pra continuar:
        </p>
        <div class="stores">
          <a class="store" href="#" data-todo="app-store">App Store</a>
          <a class="store store--alt" href="#" data-todo="google-play">Google Play</a>
        </div>
        <p>
          <a
            class="open-again"
            href="javascript:location.reload()"
            aria-label="Tentar abrir o app novamente">Tentar de novo</a
          >
        </p>
      </div>
    </main>
  </body>
</html>
